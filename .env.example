# ============================================================
# ibizacoolparty.com — Environment Variables
# Copy this file to .env and fill in your real values.
# Add all of these as Environment Variables in Vercel too.
# ============================================================

# ----------------------------------------------------------
# P1: Ticketmaster Discovery API (via Impact affiliate)
# ----------------------------------------------------------

# API key from developer.ticketmaster.com (for Discovery Feed)
TM_API_KEY=your_ticketmaster_api_key_here

# Impact campaign / affiliate tracking tag for Ticketmaster ES
# Format used in links: ?impactid=VALUE
# Find in Impact dashboard → Links & Creatives → Tracking Parameters
TM_IMPACT_TAG=your_impact_tag_here

# ----------------------------------------------------------
# P1: Booking.com Affiliate Program
# ----------------------------------------------------------

# Affiliate ID from affiliates.booking.com
BOOKING_AID=your_booking_affiliate_id_here

# ----------------------------------------------------------
# P1: GetYourGuide Affiliate Program
# ----------------------------------------------------------

# Partner ID from partner.getyourguide.com
GYG_PARTNER_ID=your_gyg_partner_id_here

# ----------------------------------------------------------
# P2: Clubtickets Ambassador (Hi Ibiza + Ushuaïa only)
# ----------------------------------------------------------

# Ambassador tag from amb.clubtickets.com
CLUBTICKETS_TAG=ibizacoolparty
