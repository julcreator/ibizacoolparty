<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0B0B14"/>
      <stop offset="50%" style="stop-color:#12122a"/>
      <stop offset="100%" style="stop-color:#0B0B14"/>
    </linearGradient>
    <linearGradient id="glow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#7c3aed;stop-opacity:0.4"/>
      <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0.2"/>
    </linearGradient>
    <filter id="blur">
      <feGaussianBlur stdDeviation="40"/>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="1200" height="630" fill="url(#bg)"/>

  <!-- Glow blobs -->
  <circle cx="200" cy="200" r="300" fill="#7c3aed" opacity="0.15" filter="url(#blur)"/>
  <circle cx="1000" cy="430" r="280" fill="#06b6d4" opacity="0.12" filter="url(#blur)"/>
  <circle cx="600" cy="600" r="200" fill="#f97316" opacity="0.08" filter="url(#blur)"/>

  <!-- Grid lines subtle -->
  <line x1="0" y1="210" x2="1200" y2="210" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="0" y1="420" x2="1200" y2="420" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="400" y1="0" x2="400" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>
  <line x1="800" y1="0" x2="800" y2="630" stroke="white" stroke-opacity="0.03" stroke-width="1"/>

  <!-- Logo / Brand -->
  <text x="600" y="220" font-family="Space Grotesk, Arial, sans-serif" font-size="72" font-weight="700" fill="white" text-anchor="middle" letter-spacing="-1">IBIZA COOL PARTY</text>

  <!-- Tagline -->
  <text x="600" y="300" font-family="Inter, Arial, sans-serif" font-size="28" font-weight="400" fill="#94a3b8" text-anchor="middle" letter-spacing="2">YOUR ULTIMATE IBIZA NIGHTLIFE GUIDE</text>

  <!-- Divider line -->
  <line x1="440" y1="335" x2="760" y2="335" stroke="#7c3aed" stroke-width="2" stroke-opacity="0.8"/>

  <!-- Tags -->
  <rect x="310" y="370" width="140" height="40" rx="20" fill="#7c3aed" fill-opacity="0.3" stroke="#7c3aed" stroke-width="1" stroke-opacity="0.6"/>
  <text x="380" y="395" font-family="Inter, Arial, sans-serif" font-size="16" fill="#c4b5fd" text-anchor="middle">Clubs</text>

  <rect x="470" y="370" width="160" height="40" rx="20" fill="#0891b2" fill-opacity="0.3" stroke="#06b6d4" stroke-width="1" stroke-opacity="0.6"/>
  <text x="550" y="395" font-family="Inter, Arial, sans-serif" font-size="16" fill="#67e8f9" text-anchor="middle">Boat Parties</text>

  <rect x="650" y="370" width="140" height="40" rx="20" fill="#ea580c" fill-opacity="0.3" stroke="#f97316" stroke-width="1" stroke-opacity="0.6"/>
  <text x="720" y="395" font-family="Inter, Arial, sans-serif" font-size="16" fill="#fdba74" text-anchor="middle">Tickets</text>

  <rect x="810" y="370" width="140" height="40" rx="20" fill="#16a34a" fill-opacity="0.3" stroke="#22c55e" stroke-width="1" stroke-opacity="0.6"/>
  <text x="880" y="395" font-family="Inter, Arial, sans-serif" font-size="16" fill="#86efac" text-anchor="middle">Hotels</text>

  <!-- URL -->
  <text x="600" y="530" font-family="Inter, Arial, sans-serif" font-size="22" fill="#475569" text-anchor="middle" letter-spacing="3">ibizacoolparty.com</text>
</svg>
