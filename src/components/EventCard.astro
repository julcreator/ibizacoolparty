---
import type { TmEvent } from '@/lib/ticketmaster';
import { getBestImage, formatPriceRange, formatEventDate, getStatusLabel } from '@/lib/ticketmaster';
import { getAffiliateAttrs } from '@/lib/affiliates';

interface Props {
  event: TmEvent;
}

const { event } = Astro.props;
const image = getBestImage(event.images);
const venue = event._embedded?.venues?.[0];
const price = formatPriceRange(event.priceRanges);
const dateStr = formatEventDate(event.dates.start.localDate, event.dates.start.localTime);
const status = event.dates.status?.code;
const statusLabel = getStatusLabel(status);
const attrs = getAffiliateAttrs();
---

<a href={`/events/${event.id}/`} class="card group block">
  <div class="aspect-[16/9] bg-dark relative overflow-hidden">
    {image ? (
      <img
        src={image.url}
        alt={event.name}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
        width={image.width}
        height={image.height}
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-purple-electric/30 to-neon-blue/20 flex items-center justify-center">
        <span class="text-white/30 text-4xl">♪</span>
      </div>
    )}
    <!-- Status badge -->
    {status && status !== 'onsale' && (
      <span class="absolute top-3 right-3 text-xs px-2 py-1 rounded-full bg-black/70 text-coral font-semibold">
        {statusLabel}
      </span>
    )}
  </div>

  <div class="p-5">
    <h3 class="font-display font-semibold text-white leading-snug line-clamp-2">
      {event.name}
    </h3>
    <p class="mt-2 text-sm text-neon-blue">{dateStr}</p>
    {venue && (
      <p class="mt-1 text-sm text-gray-400">{venue.name}</p>
    )}
    <div class="mt-3 flex items-center justify-between">
      <span class="text-sm font-semibold text-purple-electric">{price}</span>
      <span class="text-xs text-gray-500 group-hover:text-white transition-colors">View →</span>
    </div>
  </div>
</a>
