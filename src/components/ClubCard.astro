---
interface Props {
  name: string;
  slug: string;
  area: string;
  genre: string;
  bestNights: string;
  image?: string;
}

const { name, slug, area, genre, bestNights, image } = Astro.props;
---

<a href={`/clubs/${slug}/`} class="card group block">
  <div class="aspect-[16/9] bg-dark relative overflow-hidden">
    {image ? (
      <img src={image} alt={name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-purple-electric/30 to-neon-blue/20 flex items-center justify-center">
        <span class="font-display text-2xl text-white/50">{name}</span>
      </div>
    )}
  </div>
  <div class="p-5">
    <h3 class="font-display text-lg font-semibold text-white">{name}</h3>
    <div class="mt-2 flex flex-wrap gap-2">
      <span class="text-xs px-2 py-1 rounded-full bg-purple-electric/20 text-purple-electric">{genre}</span>
      <span class="text-xs px-2 py-1 rounded-full bg-neon-blue/20 text-neon-blue">{area}</span>
    </div>
    <p class="mt-3 text-sm text-gray-400">Best nights: {bestNights}</p>
    <span class="mt-4 inline-block text-sm font-semibold text-purple-electric group-hover:text-white transition-colors">
      View guide →
    </span>
  </div>
</a>
