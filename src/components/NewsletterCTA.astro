---
// Newsletter form — diseño integrado con la web, envío al endpoint de Brevo
---

<section class="bg-dark-light border border-white/5 rounded-2xl p-8 sm:p-12 text-center max-w-2xl mx-auto">
  <h3 class="font-display text-2xl font-bold text-white">Get weekly Ibiza party picks</h3>
  <p class="mt-3 text-gray-400">The best events, hotel deals and insider tips — straight to your inbox every week.</p>

  <!-- Mensajes de estado -->
  <div id="brevo-success" class="hidden mt-4 p-3 rounded-lg bg-green-900/40 border border-green-500/40 text-green-400 text-sm">
    ¡Suscrito! Revisa tu email para confirmar.
  </div>
  <div id="brevo-error" class="hidden mt-4 p-3 rounded-lg bg-red-900/40 border border-red-500/40 text-red-400 text-sm">
    Algo ha fallado. Inténtalo de nuevo.
  </div>

  <form
    id="brevo-form"
    method="POST"
    action="https://c16cbc3c.sibforms.com/serve/MUIFALukYSx5_T9MTuRLtfPK9UhlfULv6yXaKmny1rk6cKrxUwhy-X4Mbx7rv8K_FXr1Thw4IYnb26GqcMJfn9qWGa7UhRmEQL5_FBD7Ej9phnnZI7lQzEmNuW5KDYN5t_jOBTK4rfAHQa0UEBkPvvveY8HlaCgA-nlduefZQC3JCg1dib8OYiN4hIJviI0qTMkzLhElbIhwxZu0DA=="
    data-type="subscription"
    class="mt-6 flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
  >
    <input
      type="email"
      id="EMAIL"
      name="EMAIL"
      placeholder="your@email.com"
      required
      autocomplete="off"
      class="flex-1 px-4 py-3 bg-dark border border-white/10 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-purple-electric"
    />
    <button type="submit" class="btn-primary whitespace-nowrap">
      Subscribe
    </button>
    <!-- Campos ocultos requeridos por Brevo -->
    <input type="text" name="email_address_check" value="" class="hidden" />
    <input type="hidden" name="locale" value="es" />
  </form>

  <p class="mt-4 text-xs text-gray-600">No spam. Unsubscribe anytime.</p>
</section>

<script is:inline>
  const form = document.getElementById('brevo-form');
  const successMsg = document.getElementById('brevo-success');
  const errorMsg = document.getElementById('brevo-error');

  if (form) {
    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');

      const data = new FormData(form);

      try {
        await fetch(form.action, {
          method: 'POST',
          body: data,
          mode: 'no-cors',
        });
        // no-cors no devuelve status, asumimos OK si no hay excepción
        successMsg.classList.remove('hidden');
        form.reset();
      } catch {
        errorMsg.classList.remove('hidden');
      }
    });
  }
</script>
