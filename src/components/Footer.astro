---
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark-light border-t border-white/5 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div>
        <h4 class="font-display font-semibold text-white mb-4">Clubs</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><a href="/clubs/hi-ibiza/" class="hover:text-white transition-colors">Hï Ibiza</a></li>
          <li><a href="/clubs/ushuaia/" class="hover:text-white transition-colors">Ushuaïa</a></li>
          <li><a href="/clubs/pacha/" class="hover:text-white transition-colors">Pacha</a></li>
          <li><a href="/clubs/amnesia/" class="hover:text-white transition-colors">Amnesia</a></li>
          <li><a href="/clubs/dc10/" class="hover:text-white transition-colors">DC10</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display font-semibold text-white mb-4">Parties</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><a href="/boat-parties/" class="hover:text-white transition-colors">Boat Parties</a></li>
          <li><a href="/weekly-parties/" class="hover:text-white transition-colors">Weekly Parties</a></li>
          <li><a href="/pool-parties/" class="hover:text-white transition-colors">Pool Parties</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display font-semibold text-white mb-4">Travel</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><a href="/hotels/" class="hover:text-white transition-colors">Hotels</a></li>
          <li><a href="/transfers/" class="hover:text-white transition-colors">Transfers</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-display font-semibold text-white mb-4">Info</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><a href="/about/" class="hover:text-white transition-colors">About</a></li>
          <li><a href="/contact/" class="hover:text-white transition-colors">Contact</a></li>
          <li><a href="/privacy-policy/" class="hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/affiliate-disclosure/" class="hover:text-white transition-colors">Affiliate Disclosure</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} Ibiza Cool Party. All rights reserved.
      </p>
      <p class="text-xs text-gray-600">
        This site contains affiliate links. We may earn a commission at no extra cost to you.
      </p>
    </div>
  </div>
</footer>
