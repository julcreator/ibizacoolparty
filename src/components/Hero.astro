---
interface Props {
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaHref?: string;
}

const { title, subtitle, ctaText = 'Explore parties', ctaHref = '/clubs/' } = Astro.props;
---

<section class="relative py-24 sm:py-32 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-purple-electric/20 via-dark to-neon-blue/10"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-purple-electric/10 rounded-full blur-3xl"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight">
      {title}
    </h1>
    <p class="mt-6 text-lg sm:text-xl text-gray-300 max-w-2xl mx-auto">
      {subtitle}
    </p>
    
    <!-- Quick links -->
    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <a href="/clubs/" class="btn-primary">Clubs</a>
      <a href="/boat-parties/" class="btn-secondary">Boat Parties</a>
      <a href="/hotels/" class="btn-secondary">Hotels</a>
      <a href="/transfers/" class="btn-secondary">Transfers</a>
    </div>
  </div>
</section>
