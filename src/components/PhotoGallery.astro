---
import type { PexelsPhoto } from '@/lib/pexels';

interface Props {
  photos: PexelsPhoto[];
  clubName: string;
}

const { photos, clubName } = Astro.props;
---

{photos.length > 0 && (
  <section class="mb-12">
    <h2 class="font-display text-2xl font-bold text-white mb-4">
      {clubName} — Photo Gallery
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
      {photos.map((photo, i) => (
        <a
          href={photo.src.large2x}
          target="_blank"
          rel="noopener noreferrer"
          class={`group relative overflow-hidden rounded-lg bg-white/5 ${i === 0 ? 'col-span-2 sm:col-span-2 row-span-2' : ''}`}
          style={i === 0 ? 'aspect-ratio: 16/9;' : 'aspect-ratio: 4/3;'}
        >
          <img
            src={i === 0 ? photo.src.large : photo.src.medium}
            alt={photo.alt || `${clubName} Ibiza`}
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <!-- Overlay on hover -->
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300 flex items-end p-2">
            <span class="text-white/0 group-hover:text-white/70 text-xs transition-all duration-300 truncate">
              © {photo.photographer}
            </span>
          </div>
        </a>
      ))}
    </div>
    <p class="mt-2 text-xs text-gray-600">
      Photos via <a href="https://www.pexels.com" target="_blank" rel="noopener noreferrer" class="hover:text-gray-400 transition-colors">Pexels</a>
    </p>
  </section>
)}
