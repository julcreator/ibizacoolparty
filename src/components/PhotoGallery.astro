---
import type { PexelsPhoto } from '@/lib/pexels';

interface Props {
  photos: PexelsPhoto[];
  clubName: string;
}

const { photos, clubName } = Astro.props;
---

{photos.length > 0 && (
  <section class="mb-12">
    <h2 class="font-display text-2xl font-bold text-white mb-6">Photo Gallery</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {photos.map((photo, i) => (
        <a
          href={photo.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative overflow-hidden rounded-xl aspect-video block"
          aria-label={`Photo by ${photo.photographer} — ${photo.alt}`}
        >
          <img
            src={photo.src.medium}
            srcset={`${photo.src.medium} 350w, ${photo.src.large} 940w`}
            sizes="(max-width: 640px) 50vw, 33vw"
            alt={photo.alt || `${clubName} photo ${i + 1}`}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors flex items-end">
            <span class="opacity-0 group-hover:opacity-100 transition-opacity text-xs text-white p-2 truncate">
              &copy; {photo.photographer}
            </span>
          </div>
        </a>
      ))}
    </div>
    <p class="mt-2 text-xs text-gray-500">
      Photos via <a href="https://www.pexels.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-400">Pexels</a>
    </p>
  </section>
)}
