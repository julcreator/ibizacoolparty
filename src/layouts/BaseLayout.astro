---
import '@/styles/global.css';
import SEOHead from '@/components/SEOHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Analytics from '@vercel/analytics/astro';
import type { SEOProps } from '@/lib/seo';

interface Props {
  seo: SEOProps;
  schema?: object[];
}

const { seo, schema = [] } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead {...seo} />
    {schema.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
    <slot name="head" />
    <!-- Impact.com universal impression tracking -->
    <script type="text/javascript" is:inline>
      (function(i,m,p,a,c,t){c.ire_o=p;c[p]=c[p]||function(){(c[p].a=c[p].a||[]).push(arguments)};t=a.createElement(m);var z=a.getElementsByTagName(m)[0];t.async=1;t.src=i;z.parentNode.insertBefore(t,z)})('https://utt.impactcdn.com/P-A1937693-6205-4997-a28a-41540cb77dab1.js','script','impactStat',document,window);impactStat('trackImpression');
    </script>
  </head>
  <body>
    <Header />
    <main class="pt-16">
      <slot />
    </main>
    <Footer />
    <SpeedInsights />
    <Analytics />
  </body>
</html>
