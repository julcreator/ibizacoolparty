---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AffiliateButton from '@/components/AffiliateButton.astro';
import { generateBreadcrumbSchema } from '@/lib/seo';

const seo = {
  title: 'Best Party Hotels in Ibiza – Stay Near the Clubs | Ibiza Cool Party',
  description: 'Find the best hotels near Ibiza\'s top clubs. From budget-friendly stays in Playa d\'en Bossa to boutique hotels in Ibiza Town — book the perfect base for your party trip.',
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Hotels', url: '/hotels/' },
];
const schema = [generateBreadcrumbSchema(breadcrumbs, 'https://www.ibizacoolparty.com')];

const zones = [
  {
    name: 'Playa d\'en Bossa',
    description: 'Home to Ushuaïa and Hï Ibiza. The epicenter of Ibiza partying — walk to the biggest clubs.',
    bookingUrl: 'https://www.booking.com/searchresults.html?ss=Playa+d%27en+Bossa%2C+Ibiza',
  },
  {
    name: 'Ibiza Town (Eivissa)',
    description: 'Close to Pacha and the vibrant port. Great restaurants, bars, and nightlife variety.',
    bookingUrl: 'https://www.booking.com/searchresults.html?ss=Ibiza+Town',
  },
  {
    name: 'San Antonio',
    description: 'Famous sunset strip and lively bar scene. Budget-friendly with great pre-party vibes.',
    bookingUrl: 'https://www.booking.com/searchresults.html?ss=San+Antonio%2C+Ibiza',
  },
];
---

<BaseLayout seo={seo} schema={schema}>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <h1 class="font-display text-4xl sm:text-5xl font-bold text-white">Party Hotels in Ibiza</h1>
    <p class="mt-4 text-lg text-gray-300 max-w-3xl">
      Where you stay matters. Be close to the action — choose a hotel near your favorite clubs and skip the expensive late-night taxis.
    </p>

    <div class="mt-12 grid gap-6">
      {zones.map((zone) => (
        <div class="card p-6 sm:p-8">
          <h2 class="font-display text-xl font-bold text-white">{zone.name}</h2>
          <p class="mt-2 text-gray-300">{zone.description}</p>
          <div class="mt-4">
            <AffiliateButton href={zone.bookingUrl}>
              See hotels in {zone.name}
            </AffiliateButton>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
