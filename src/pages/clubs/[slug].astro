---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PhotoGallery from '@/components/PhotoGallery.astro';
import YouTubeEmbed from '@/components/YouTubeEmbed.astro';
import { generateBreadcrumbSchema, generateFAQSchema } from '@/lib/seo';
import { hasClubticketsP2, buildClubticketsUrl } from '@/lib/affiliates';
import { fetchClubPhotos } from '@/lib/pexels';
import { clubs } from '@/data/clubs';

export async function getStaticPaths() {
  const paths = await Promise.all(
    clubs.map(async (club) => {
      const photos = await fetchClubPhotos(
        club.pexelsQuery ?? `${club.name} Ibiza nightclub`,
        6
      );
      return {
        params: { slug: club.slug },
        props: { club, photos },
      };
    })
  );
  return paths;
}

const { club, photos } = Astro.props;

const showClubticketsP2 = hasClubticketsP2(club.slug) && !!club.clubticketsUrl;

const seo = {
  title: `${club.name} Tickets, Best Nights & Guide | Ibiza Cool Party`,
  description: `Everything about ${club.name}: best nights, tickets, dress code, how to get there, and hotels nearby in ${club.area}. Your complete guide.`,
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Clubs', url: '/clubs/' },
  { name: club.name, url: `/clubs/${club.slug}/` },
];

const schema = [
  generateBreadcrumbSchema(breadcrumbs, 'https://www.ibizacoolparty.com'),
  ...(club.faqs.length > 0 ? [generateFAQSchema(club.faqs)] : []),
];
---

<BaseLayout seo={seo} schema={schema}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <!-- Hero -->
    <div class="mb-12">
      <nav class="text-sm text-gray-400 mb-4">
        <a href="/" class="hover:text-white">Home</a> /
        <a href="/clubs/" class="hover:text-white">Clubs</a> /
        <span class="text-white">{club.name}</span>
      </nav>
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-white">{club.name}</h1>
      <div class="mt-4 flex flex-wrap gap-3">
        <span class="text-sm px-3 py-1 rounded-full bg-purple-electric/20 text-purple-electric">{club.genre}</span>
        <span class="text-sm px-3 py-1 rounded-full bg-neon-blue/20 text-neon-blue">{club.area}</span>
        <span class="text-sm px-3 py-1 rounded-full bg-coral/20 text-coral">{club.priceRange}</span>
      </div>
    </div>

    <!-- Description -->
    <section class="prose prose-invert max-w-none mb-12">
      <p class="text-lg text-gray-300 leading-relaxed">{club.description}</p>
    </section>

    <!-- Photo Gallery (Pexels) -->
    <PhotoGallery photos={photos} clubName={club.name} />

    <!-- Key Info -->
    <section class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
      <div class="card p-5">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">Capacity</h3>
        <p class="mt-1 text-white font-semibold">{club.capacity}</p>
      </div>
      <div class="card p-5">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">Best Nights</h3>
        <p class="mt-1 text-white font-semibold">{club.bestNights}</p>
      </div>
      <div class="card p-5">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">Dress Code</h3>
        <p class="mt-1 text-white font-semibold">{club.dressCode}</p>
      </div>
      <div class="card p-5">
        <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider">Price Range</h3>
        <p class="mt-1 text-white font-semibold">{club.priceRange}</p>
      </div>
    </section>

    <!-- CTA: Tickets -->
    <section class="card p-8 mb-6 text-center bg-gradient-to-r from-purple-electric/10 to-neon-blue/10">
      <h2 class="font-display text-2xl font-bold text-white mb-2">Get Official Tickets</h2>
      <p class="text-gray-300 text-sm mb-6">
        Secure booking via official platforms
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`https://www.clubtickets.com/${club.slug}`} target="_blank" rel="sponsored nofollow noopener" class="btn-primary">
          Buy tickets on Clubtickets
        </a>
      </div>
    </section>

    <!-- CTA: Clubtickets P2 — Hi Ibiza & Ushuaïa only -->
    {showClubticketsP2 && (
      <section class="card p-5 mb-12 text-center border-dashed">
        <p class="text-sm text-gray-400 mb-3">
          Also available on official channels
        </p>
        <a href={buildClubticketsUrl(`/${club.slug}`)} target="_blank" rel="sponsored nofollow noopener" class="btn-secondary">
          Check on Clubtickets
        </a>
      </section>
    )}

    <!-- YouTube Videos -->
    {club.youtubeVideos && club.youtubeVideos.length > 0 && (
      <section class="mb-12">
        <h2 class="font-display text-2xl font-bold text-white mb-6">Official Videos & Aftermovies</h2>
        <div class={`grid gap-4 ${club.youtubeVideos.length === 1 ? 'grid-cols-1' : 'grid-cols-1 sm:grid-cols-2'}`}>
          {club.youtubeVideos.map((video) => (
            <YouTubeEmbed videoId={video.id} title={video.title} />
          ))}
        </div>
      </section>
    )}

    <!-- FAQs -->
    {club.faqs.length > 0 && (
      <section class="mb-12">
        <h2 class="font-display text-2xl font-bold text-white mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {club.faqs.map((faq) => (
            <details class="card p-5 group">
              <summary class="font-semibold text-white cursor-pointer list-none flex justify-between items-center">
                {faq.question}
                <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="mt-3 text-gray-300">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
